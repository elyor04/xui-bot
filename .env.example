# ── Telegram ─────────────────────────────────────────────────────────────
BOT_TOKEN=
# Comma-separated Telegram user IDs that are always admins
ADMIN_IDS=11111111,22222222

# ── 3x-ui panel ──────────────────────────────────────────────────────────
# Base URL WITHOUT trailing slash
XUI_BASE_URL=
# Web base path the panel is served under (3x-ui webBasePath). Usually "/"
XUI_BASE_PATH=/
# Preferred auth: Bearer token from Settings → Security → API Token
XUI_API_TOKEN=
# Fallback auth (used only when no token is set):
XUI_USERNAME=
XUI_PASSWORD=
# Set to false for self-signed certs
XUI_VERIFY_SSL=true
XUI_TIMEOUT=30

# Public subscription base shown to clients (Settings → Subscription)
SUB_BASE_URL=

# Default inbound IDs (optional) and create-flow defaults
DEFAULT_INBOUND_IDS=
DEFAULT_QUOTA_GB=50
DEFAULT_DAYS=30

# Scheduled report: send server + depleting-soon summary to all admin_ids
# every N hours. 0 = disabled.
REPORT_INTERVAL_HOURS=12

# ── Local database (tortoise-orm) ────────────────────────────────────────
# SQLite (default):
DB_URL=sqlite://bot.sqlite3
# PostgreSQL (requires asyncpg):
# DB_URL=postgres://user:pass@localhost:5432/xui_bot
